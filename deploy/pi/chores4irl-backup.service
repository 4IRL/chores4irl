[Unit]
Description=chores4irl SQLite backup (oneshot)
Requires=chores4irl.service
After=chores4irl.service docker.service

[Service]
Type=oneshot
# Path matches the actual Pi (user rmilarachi, home /home/rmilarachi).
# Substitute /home/rmilarachi if your Pi login differs.
ExecStart=/home/rmilarachi/chores4irl/bin/chores4irl-backup.sh
# REQUIRED: off-Pi backup destination. The script refuses to run without it,
# because on-card-only backups don't survive an SD-card failure. Point at a LAN
# host / NAS reachable over SSH (key-based auth, no passphrase prompt):
Environment=BACKUP_RSYNC_DEST=user@nas:/srv/backups/chores4irl
